spring.application.name=zakaflow

# Wajib di Railway/proxy agar OAuth2 redirect URI memakai https + domain publik (bukan host internal)
server.forward-headers-strategy=framework

# Google OAuth2 — set di Railway Variables (atau salin ke application.properties lokal)
spring.security.oauth2.client.registration.google.client-id=${GOOGLE_CLIENT_ID}
spring.security.oauth2.client.registration.google.client-secret=${GOOGLE_CLIENT_SECRET}
spring.security.oauth2.client.registration.google.scope=openid,profile,email
# Default Spring Security; daftarkan persis ini di Google Cloud Console → Authorized redirect URIs
spring.security.oauth2.client.registration.google.redirect-uri={baseUrl}/login/oauth2/code/{registrationId}
spring.security.oauth2.client.provider.google.issuer-uri=https://accounts.google.com

spring.datasource.url=MASUKKAN_LINK_JDBC_SUPABASE_KALIAN
spring.datasource.username=postgres
spring.datasource.password=MASUKKAN_PASSWORD_DATABASE_SUPABASE_KALIAN

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# Informasi rekening / pembayaran (donatur bisa transfer dari bank manapun)
zakaflow.payment.qris-merchant=ZakaFlow Donasi
zakaflow.payment.ewallet-info=GoPay / OVO / DANA — 081234567890 (a.n. ZakaFlow)

# Daftar rekening tujuan (boleh lebih dari satu bank)
zakaflow.payment.bank-accounts[0].bank-name=BCA
zakaflow.payment.bank-accounts[0].account-number=1234567890
zakaflow.payment.bank-accounts[0].account-holder=Yayasan ZakaFlow
