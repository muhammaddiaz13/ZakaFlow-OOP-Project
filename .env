# ZakaFlow Database Configuration Example
# Salin file ini menjadi '.env' (atau setel variabel ini di IDE / Environment OS Anda)
# untuk menghubungkan aplikasi ke Supabase atau database PostgreSQL Anda lainnya.

# URL koneksi JDBC PostgreSQL Supabase (Menggunakan Pooler IPv4 agar mendukung jaringan lokal)
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Username database Supabase (Format: username.project-ref untuk Pooler)
SPRING_DATASOURCE_USERNAME=postgres.szvoiuccuwcbguchvfxm

# Password database Supabase
SPRING_DATASOURCE_PASSWORD=Willyam13042006//

spring.datasource.hikari.maximum-pool-size=2